# Relay Configuration Template
# Copy relevant sections into relay.yaml and customize.
# Bot tokens use ${ENV_VAR} syntax — resolved from .env at startup.

agents:
  # Example agent — one block per bot
  my_agent:
    bot_token: ${MY_AGENT_BOT_TOKEN}
    allowed_users:
      - 123456789  # Telegram user ID
    project_dir: "/home/ubuntu/my_project"
    allowed_tools:
      - "Read"
      - "Glob"
      - "Grep"
      - "Edit"
      - "Write"
      - "Bash"
      - "Agent"
    model: "sonnet"          # sonnet | opus | haiku
    timeout: 900             # max seconds per claude invocation
    session_ttl: 14400       # session expiry (seconds), default 4h
    max_budget: 1.0          # max USD per invocation

    # Optional: cron jobs (runs inside relay process)
    # crons:
    #   - name: daily_task
    #     prompt_file: crons/task.md   # relative to project_dir
    #     schedule: '0 12 * * *'       # cron expression (UTC)
    #     notify: true                 # send output to Telegram
    #     skip_if_active: false        # skip if user has active session

voice:
  backend: "vox"  # "vox" or "openai"

storage:
  db_path: "relay.db"
