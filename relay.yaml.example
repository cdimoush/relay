# Relay v1.0 Configuration
# Copy to relay.yaml and edit values.
# Environment variables can be referenced with ${VAR_NAME}.

agents:
  isaac:
    bot_token: ${TELEGRAM_BOT_TOKEN_ISAAC}
    allowed_users:
      - 123456789        # Your Telegram user ID
    project_dir: "/home/ubuntu/isaac_research"
    allowed_tools:
      - "Read"
      - "Glob"
      - "Grep"
      - "Edit"
      - "Write"
      - "Bash"
      - "Agent"
    model: "sonnet"
    timeout: 900         # 15 minutes
    session_ttl: 14400   # 4 hours
    max_budget: 1.0      # $1.00 per agent call

  webdev:
    bot_token: ${TELEGRAM_BOT_TOKEN_WEBDEV}
    allowed_users:
      - 123456789
      - 987654321        # Second user
    project_dir: "/home/ubuntu/webdev_project"
    allowed_tools:
      - "Read"
      - "Glob"
      - "Grep"
      - "Edit"
      - "Write"
      - "Bash"
    model: "sonnet"
    timeout: 600         # 10 minutes
    session_ttl: 7200    # 2 hours
    max_budget: 0.50

voice:
  backend: "vox"         # "vox" or "openai"

storage:
  db_path: "relay.db"

# Discord integration (optional — omit entire section to disable)
# discord:
#   bot_token: ${DISCORD_BOT_TOKEN}
#   guild_id: 1234567890123456788
#   allowed_users:          # Discord user IDs (optional — omit for no auth check)
#     - 123456789012345678
#
# Per-agent Discord config (add under each agent):
#   discord:
#     chat_channel: 1234567890123456789
